{
  "compilerOptions": {
    "target": "ESNext",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "types": ["node", "@playwright/test"],
    "outDir": "./dist",
    "rootDir": "."
  },
  "include": ["pages/**/*", "tests/**/*", "utils/**/*", "playwright.config.ts"],
  "exclude": ["node_modules", "dist"]
}
